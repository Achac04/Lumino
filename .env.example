# Canonical site URL for Open Graph and metadata (no trailing slash).
# On Vercel: Project → Settings → Environment Variables
# Example: https://lumina-lore.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# If `next dev` shows SegmentViewNode / client-manifest errors after upgrades,
# stop the server, delete the `.next` folder, and run `npm run dev` again.
